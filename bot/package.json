{
  "name": "pedaldata-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Bot WhatsApp + DeepSeek + Gemini + GitHub para blog de ciclismo automático",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "post:manual": "node src/manual.js",
    "batch": "node src/batch.js",
    "batch:30": "node src/batch.js 1 30",
    "publish": "node src/publish_post.js",
    "lint": "node scripts/check-js.mjs",
    "test": "node test_schema.mjs",
    "validate:research": "node src/validation/validate-research.js",
    "validate:posts": "node src/validate_posts.js",
    "validate:images": "node src/validation/validate-images.js",
    "check:claims": "node src/validation/check-claims.js",
    "build:jekyll": "bundle exec jekyll build --baseurl \"\"",
    "generate": "node src/generator.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.0",
    "gray-matter": "^4.0.3",
    "puppeteer": "^23.0.0",
    "qrcode-terminal": "^0.12.0",
    "sanitize-html": "^2.17.6",
    "simple-git": "^3.27.0",
    "whatsapp-web.js": "^1.26.0",
    "zod": "^4.4.3"
  }
}
