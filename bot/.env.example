# === IA ===
# DeepSeek é a primeira opção; Gemini fica como fallback.
DEEPSEEK_API_KEY=sua_chave_deepseek_aqui
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_TOKENS=4096
GEMINI_API_KEY=sua_chave_gemini_aqui

# === GITHUB ===
GITHUB_TOKEN=seu_github_token
GITHUB_USER=seu_usuario
GITHUB_REPO=pedaldata
GITHUB_BRANCH=main

# === BLOG ===
BLOG_TITLE="Pedal Data"
BLOG_URL=https://seu_usuario.github.io/pedaldata
AUTHOR_NAME="Equipe Pedal Data"

# === SEGURANÇA ===
# Números do WhatsApp autorizados (formato: DDI+DDD+número, separados por vírgula)
# Deixe vazio para aceitar qualquer número (não recomendado em produção)
AUTHORIZED_WHATSAPP_NUMBERS=
# Limite diário de solicitações por número
DAILY_REQUEST_LIMIT=10

# === SERVIDOR ===
PORT=3000
